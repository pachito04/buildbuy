# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supavisor pooled connection string — use port 6543, not 5432
# Find in: Supabase Dashboard → Project Settings → Database → Connection String → Supavisor
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp (configure once provider is chosen) ──────────────────────────────
# Twilio:
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=+14155238886

# Meta WhatsApp Business API:
# META_VERIFY_TOKEN=your_random_secret_string

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Comma-separated origins for CORS (add your Vercel frontend URL in production)
# CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]
